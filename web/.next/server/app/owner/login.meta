{
  "headers": {
    "x-nextjs-stale-time": "300",
    "x-nextjs-prerender": "1",
    "x-next-cache-tags": "_N_T_/layout,_N_T_/owner/layout,_N_T_/owner/login/layout,_N_T_/owner/login/page,_N_T_/owner/login"
  },
  "segmentPaths": [
    "/_tree",
    "/_full",
    "/owner/login/__PAGE__",
    "/owner/login",
    "/owner",
    "/_index",
    "/_head"
  ]
}