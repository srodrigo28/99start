{
  "headers": {
    "x-nextjs-stale-time": "300",
    "x-nextjs-prerender": "1",
    "x-next-cache-tags": "_N_T_/layout,_N_T_/owner/layout,_N_T_/owner/register/layout,_N_T_/owner/register/page,_N_T_/owner/register"
  },
  "segmentPaths": [
    "/_tree",
    "/_full",
    "/owner/register/__PAGE__",
    "/owner/register",
    "/owner",
    "/_index",
    "/_head"
  ]
}