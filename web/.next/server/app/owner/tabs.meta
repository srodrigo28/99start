{
  "headers": {
    "x-nextjs-stale-time": "300",
    "x-nextjs-prerender": "1",
    "x-next-cache-tags": "_N_T_/layout,_N_T_/owner/layout,_N_T_/owner/tabs/layout,_N_T_/owner/tabs/page,_N_T_/owner/tabs"
  },
  "segmentPaths": [
    "/_tree",
    "/_full",
    "/owner/tabs/__PAGE__",
    "/owner/tabs",
    "/owner",
    "/_index",
    "/_head"
  ]
}