{
  "headers": {
    "x-nextjs-stale-time": "300",
    "x-nextjs-prerender": "1",
    "x-next-cache-tags": "_N_T_/layout,_N_T_/owner/layout,_N_T_/owner/settings/layout,_N_T_/owner/settings/page,_N_T_/owner/settings"
  },
  "segmentPaths": [
    "/_tree",
    "/_full",
    "/owner/settings/__PAGE__",
    "/owner/settings",
    "/owner",
    "/_index",
    "/_head"
  ]
}